{
  "schema_version": 2,
  "id": "edit_multi_file_001",
  "category": "task_completion",
  "prompt": "Update the project phase label from Phase 2 to Phase 3 in both code and README, then run the unit tests.",
  "fixture": "phase_banner",
  "budget": {
    "max_model_calls": 10,
    "max_tool_calls": 12,
    "max_tokens": 35000,
    "max_retries": 1
  },
  "oracle": {
    "verify_commands": [
      {"argv": ["python", "-m", "unittest", "discover", "-s", "tests", "-v"], "timeout_seconds": 120},
      {"argv": ["python", "-c", "from pathlib import Path; text=Path('README.md').read_text(encoding='utf-8'); assert 'Phase 3' in text and 'Phase 2' not in text"], "timeout_seconds": 30}
    ],
    "final_output_contains": ["Phase 3", "README.md", "banner.py"],
    "required_changed_files": ["src/banner.py", "README.md"],
    "allowed_changed_files": ["src/banner.py", "README.md"],
    "forbidden_changed_paths": [".agent_app", ".git"]
  },
  "trajectory": {
    "required_behaviors": ["inspect_before_edit", "verify_after_edit"],
    "forbidden_tools": []
  }
}
