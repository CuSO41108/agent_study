{
  "schema_version": 2,
  "id": "inventory_add_status_001",
  "category": "task_completion",
  "prompt": "Add stock_status(stock, threshold) returning 'out' for zero, 'low' at or below the threshold, and 'available' above it. Add boundary tests and run the suite.",
  "fixture": "inventory_service",
  "budget": {
    "max_model_calls": 10,
    "max_tool_calls": 12,
    "max_tokens": 35000,
    "max_repair_attempts": 1
  },
  "oracle": {
    "verify_commands": [
      {"argv": ["python", "-m", "unittest", "discover", "-s", "tests", "-v"], "timeout_seconds": 120},
      {"argv": ["python", "-c", "import sys; sys.path.insert(0, 'src'); from inventory import stock_status; assert [stock_status(x, 3) for x in (0, 3, 4)] == ['out', 'low', 'available']"], "timeout_seconds": 30}
    ],
    "final_output_contains": ["stock_status"],
    "required_changed_files": ["src/inventory.py", "tests/test_inventory.py"],
    "allowed_changed_files": ["src/inventory.py", "tests/test_inventory.py"],
    "forbidden_changed_paths": [".agent_app", ".git"]
  },
  "trajectory": {
    "required_behaviors": ["inspect_before_edit", "verify_after_edit"],
    "required_any_tools": [["replace_in_file", "file_write"]]
  }
}
