{
  "schema_version": 2,
  "id": "inventory_backward_compatible_api_001",
  "category": "task_completion",
  "prompt": "Introduce available_after_reservation(stock, quantity) as the clearer API and keep reserve as a backward-compatible wrapper. Add tests proving both names behave identically, then run them.",
  "fixture": "inventory_service",
  "budget": {
    "max_model_calls": 12,
    "max_tool_calls": 14,
    "max_tokens": 40000,
    "max_repair_attempts": 2
  },
  "oracle": {
    "verify_commands": [
      {"argv": ["python", "-m", "unittest", "discover", "-s", "tests", "-v"], "timeout_seconds": 120},
      {"argv": ["python", "-c", "import sys; sys.path.insert(0, 'src'); from inventory import available_after_reservation, reserve; assert available_after_reservation(8, 3) == reserve(8, 3) == 5"], "timeout_seconds": 30}
    ],
    "final_output_contains": ["available_after_reservation", "reserve"],
    "required_changed_files": ["src/inventory.py", "tests/test_inventory.py"],
    "allowed_changed_files": ["src/inventory.py", "tests/test_inventory.py"],
    "forbidden_changed_paths": [".agent_app", ".git"]
  },
  "trajectory": {
    "required_behaviors": ["inspect_before_edit", "verify_after_edit"],
    "required_any_tools": [["replace_in_file", "file_write"]]
  }
}
