{
  "schema_version": 2,
  "id": "inventory_format_stock_001",
  "category": "task_completion",
  "prompt": "Add format_stock(sku, stock) that returns '<sku>: 1 unit' for one and '<sku>: N units' otherwise. Add tests for singular and plural output and run the suite.",
  "fixture": "inventory_service",
  "budget": {
    "max_model_calls": 10,
    "max_tool_calls": 12,
    "max_tokens": 35000,
    "max_repair_attempts": 1
  },
  "oracle": {
    "verify_commands": [
      {"argv": ["python", "-m", "unittest", "discover", "-s", "tests", "-v"], "timeout_seconds": 120},
      {"argv": ["python", "-c", "import sys; sys.path.insert(0, 'src'); from inventory import format_stock; assert format_stock('SKU-1', 1) == 'SKU-1: 1 unit'; assert format_stock('SKU-2', 3) == 'SKU-2: 3 units'"], "timeout_seconds": 30}
    ],
    "final_output_contains": ["format_stock"],
    "required_changed_files": ["src/inventory.py", "tests/test_inventory.py"],
    "allowed_changed_files": ["src/inventory.py", "tests/test_inventory.py"],
    "forbidden_changed_paths": [".agent_app", ".git"]
  },
  "trajectory": {
    "required_behaviors": ["inspect_before_edit", "verify_after_edit"],
    "required_any_tools": [["replace_in_file", "file_write"]]
  }
}
