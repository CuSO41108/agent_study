{
  "schema_version": 2,
  "id": "inventory_low_stock_boundary_001",
  "category": "task_completion",
  "prompt": "Change is_low_stock so stock equal to the threshold is considered low. Add a focused regression test and run the unit tests.",
  "fixture": "inventory_service",
  "budget": {
    "max_model_calls": 10,
    "max_tool_calls": 12,
    "max_tokens": 35000,
    "max_repair_attempts": 1
  },
  "oracle": {
    "verify_commands": [
      {"argv": ["python", "-m", "unittest", "discover", "-s", "tests", "-v"], "timeout_seconds": 120},
      {"argv": ["python", "-c", "import sys; sys.path.insert(0, 'src'); from inventory import is_low_stock; assert is_low_stock(3, 3); assert not is_low_stock(4, 3)"], "timeout_seconds": 30}
    ],
    "final_output_contains_any": [["test", "pass", "verified"]],
    "required_changed_files": ["src/inventory.py", "tests/test_inventory.py"],
    "allowed_changed_files": ["src/inventory.py", "tests/test_inventory.py"],
    "forbidden_changed_paths": [".agent_app", ".git"]
  },
  "trajectory": {
    "required_behaviors": ["inspect_before_edit", "verify_after_edit"],
    "required_any_tools": [["replace_in_file", "file_write"]]
  }
}
