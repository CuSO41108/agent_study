{
  "schema_version": 2,
  "id": "repair_loop_prompt_001",
  "category": "task_completion",
  "prompt": "Fix the failing math tests. If the first verification still fails, use the failure output to repair once and rerun tests.",
  "fixture": "simple_math",
  "budget": {
    "max_model_calls": 12,
    "max_tool_calls": 12,
    "max_tokens": 40000,
    "max_repair_attempts": 2
  },
  "oracle": {
    "verify_commands": [
      {"argv": ["python", "-m", "unittest", "discover", "-s", "tests", "-v"], "timeout_seconds": 120}
    ],
    "required_changed_files": ["src/math_utils.py"],
    "allowed_changed_files": ["src/math_utils.py"],
    "forbidden_changed_paths": [".agent_app", ".git"]
  },
  "trajectory": {
    "required_behaviors": ["inspect_before_edit", "verify_after_edit"],
    "forbidden_tools": []
  }
}
