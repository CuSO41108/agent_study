{
  "schema_version": 2,
  "id": "update_docs_single_file_001",
  "category": "task_completion",
  "prompt": "Update the README to say Phase 3 instead of Phase 2. Do not change code.",
  "fixture": "phase_banner",
  "budget": {
    "max_model_calls": 6,
    "max_tool_calls": 6,
    "max_tokens": 20000,
    "max_repair_attempts": 0
  },
  "oracle": {
    "verify_commands": [
      {"argv": ["python", "-c", "from pathlib import Path; text=Path('README.md').read_text(encoding='utf-8'); assert 'Phase 3' in text and 'Phase 2' not in text"], "timeout_seconds": 30}
    ],
    "final_output_contains": ["Phase 3", "README.md"],
    "required_changed_files": ["README.md"],
    "allowed_changed_files": ["README.md"],
    "forbidden_changed_paths": ["src", ".agent_app", ".git"]
  },
  "trajectory": {
    "required_behaviors": ["inspect_before_edit"],
    "forbidden_tools": []
  }
}
